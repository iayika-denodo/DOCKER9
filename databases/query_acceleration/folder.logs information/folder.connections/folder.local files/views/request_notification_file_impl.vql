CREATE OR REPLACE VIEW request_notification_file_impl FOLDER = '/logs information/connections/local files' AS SELECT bv_request_notification_file.servername AS servername, bv_request_notification_file.host AS host, bv_request_notification_file.port AS port, bv_request_notification_file.id AS id, bv_request_notification_file.databasename AS databasename, bv_request_notification_file.username AS username, bv_request_notification_file.notificationtype AS notificationtype, bv_request_notification_file.sessionid AS sessionid, to_timestamp('yyyy-MM-dd''T''HH:mm:ss.SSS', start_time_as_text) AS starttime, to_timestamp('yyyy-MM-dd''T''HH:mm:ss.SSS', end_time_as_text) AS endtime, cast('long', bv_request_notification_file.duration_as_text) AS duration, cast('long', bv_request_notification_file.waiting_time_as_text) AS waitingtime, cast('int', bv_request_notification_file.num_rows_as_text) AS numrows, bv_request_notification_file.state AS state, bv_request_notification_file.completed_as_text AS completed_as_text, bv_request_notification_file.cache_as_text AS cache_as_text, bv_request_notification_file.query AS query, bv_request_notification_file.requesttype AS requesttype, bv_request_notification_file.elements AS elements, bv_request_notification_file.useragent AS useragent, bv_request_notification_file.accessinterface AS accessinterface, bv_request_notification_file.clientip AS clientip, bv_request_notification_file.transaction_id_as_text AS transaction_id_as_text, bv_request_notification_file.webservicename AS webservicename, bv_request_notification_file.logs_path AS logs_path FROM bv_request_notification_file WHERE (logs_path = '/opt/denodo/logs/monitor/logs' AND search_start_date = DATE '1970-01-01' AND log_prefix = 'vdp');

ALTER VIEW request_notification_file_impl
 LAYOUT (bv_request_notification_file = [20, 20, 288, 435]);

